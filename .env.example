# Copy to .env and adjust. docker compose reads it automatically.

# --- MinIO / data lake ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
S3_BUCKET=sepa-datalake

# --- Airflow ---
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin
# Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=Zp8kfjP0Y3nH2sVxQwLmTgRcBdNaEuIoYkXzMvCbAhE=
AIRFLOW_SECRET_KEY=sepa-pipeline-dev-secret
# On Linux, set to your own uid so files written into ./logs stay writable:
#   echo "AIRFLOW_UID=$(id -u)" >> .env
AIRFLOW_UID=50000

# --- Pipeline tuning ---
# Rows per CSV chunk during the Silver transform.
SEPA_CHUNK_SIZE=250000
# How many days back the daily run looks when closing gaps (0-7). The portal
# only keeps 7 days, so a larger number cannot find anything. Set to 1 for a
# strict "yesterday only" job with no self-healing.
SEPA_BACKFILL_MAX_DAYS=7
# Limit how many per-retailer archives are processed. 0 = all.
# Set to 3 for a fast end-to-end smoke test of the stack.
SEPA_MAX_COMERCIOS=0
# Enable the (opt-in) product category filter.
SEPA_ENABLE_CATEGORY_FILTER=false
SEPA_LOG_LEVEL=INFO
